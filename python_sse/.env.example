# Cisco Meraki API Configuration
MERAKI_API_KEY=your-meraki-api-key-here

# Privileged users (comma-separated list)
# These users can perform dangerous operations like reboots and deletions
PRIVILEGED_USERS=admin@example.com,david@skycomm.com

# Rate limiting configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Server configuration
HOST=0.0.0.0
PORT=8000